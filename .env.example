APP_NAME=Vanguarr
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
TZ=America/New_York

DATABASE_URL=sqlite:////app/config/vanguarr.db
PROFILES_DIR=/app/config/profiles
GLOBAL_EXCLUSIONS=No Horror,No Reality TV
REQUEST_THRESHOLD=0.72
SCHEDULER_ENABLED=true
PROFILE_CRON=0 3 * * 0
DECISION_CRON=0 4 * * *
HEALTH_CACHE_SECONDS=30
PROFILE_HISTORY_LIMIT=40
CANDIDATE_LIMIT=25
RECOMMENDATION_SEED_LIMIT=3
DECISION_PAGE_SIZE=100

JELLYFIN_BASE_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

SEER_BASE_URL=http://jellyseerr:5055
SEER_API_KEY=
SEER_REQUEST_USER_ID=

LLM_PROVIDER=ollama
LLM_MODEL=ollama/llama3.1:8b
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=700
LLM_TIMEOUT_SECONDS=45

OLLAMA_API_BASE=http://ollama:11434
OPENAI_API_KEY=
OPENAI_API_BASE=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
