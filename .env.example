#
# Bootstrap settings
# These are still read directly from the environment at startup.
#

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
VANGUARR_DATA_PATH=./data

DATA_DIR=/data
DATABASE_URL=sqlite:////data/vanguarr.db
PROFILES_DIR=/data/profiles
LOGS_DIR=/data/logs
LOG_FILE=/data/logs/vanguarr.log

#
# Runtime setting seeds
# These values are imported into the database-backed settings store on startup
# when the corresponding DB row does not exist yet. After first boot, use the
# Settings page to manage them live without restarting the app.
#

APP_NAME=Vanguarr
TZ=America/New_York
LOG_LEVEL=INFO
HEALTH_CACHE_SECONDS=30

MEDIA_SERVER_PROVIDER=jellyfin
JELLYFIN_BASE_URL=http://jellyfin:8096
JELLYFIN_API_KEY=
PLEX_BASE_URL=http://plex:32400
PLEX_API_TOKEN=
PLEX_CLIENT_IDENTIFIER=vanguarr

SEER_BASE_URL=http://jellyseerr:5055
SEER_API_KEY=
SEER_REQUEST_USER_ID=
SEER_WEBHOOK_TOKEN=
SUGGESTIONS_API_KEY=

TMDB_API_READ_ACCESS_TOKEN=
TMDB_API_KEY=
TMDB_LANGUAGE=en-US
TMDB_WATCH_REGION=US

SCHEDULER_ENABLED=true
PROFILE_CRON=0 3 * * 0
DECISION_CRON=0 4 * * *
SUGGESTIONS_ENABLED=true
SUGGESTIONS_LIMIT=20
REQUEST_THRESHOLD=0.72
GLOBAL_EXCLUSIONS=No Horror,No Reality TV

LLM_PROVIDER=ollama
LLM_MODEL=glm-4.7-flash:latest
LLM_TIMEOUT_SECONDS=
OLLAMA_API_BASE=http://ollama:11434
OPENAI_API_KEY=
OPENAI_API_BASE=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
