APP_NAME=Vanguarr
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
TZ=America/New_York
VANGUARR_DATA_PATH=./data

DATA_DIR=/data
DATABASE_URL=sqlite:////data/vanguarr.db
PROFILES_DIR=/data/profiles
LOGS_DIR=/data/logs
LOG_FILE=/data/logs/vanguarr.log
LOG_LEVEL=INFO
GLOBAL_EXCLUSIONS=No Horror,No Reality TV
REQUEST_THRESHOLD=0.72
SCHEDULER_ENABLED=true
PROFILE_CRON=0 3 * * 0
DECISION_CRON=0 4 * * *
HEALTH_CACHE_SECONDS=30
PROFILE_HISTORY_LIMIT=40
PROFILE_ARCHITECT_MAX_OUTPUT_TOKENS=384
PROFILE_ARCHITECT_TOP_TITLES_LIMIT=8
PROFILE_ARCHITECT_RECENT_MOMENTUM_LIMIT=5
PROFILE_LLM_ENRICHMENT_ENABLED=true
PROFILE_LLM_ENRICHMENT_MAX_OUTPUT_TOKENS=120
CANDIDATE_LIMIT=160
TRENDING_CANDIDATE_LIMIT=100
DECISION_SHORTLIST_LIMIT=15
RECOMMENDATION_SEED_LIMIT=6
TMDB_SEED_ENRICHMENT_LIMIT=6
TMDB_CANDIDATE_ENRICHMENT_LIMIT=30
DECISION_PAGE_SIZE=100

JELLYFIN_BASE_URL=http://jellyfin:8096
JELLYFIN_API_KEY=

SEER_BASE_URL=http://jellyseerr:5055
SEER_API_KEY=
SEER_REQUEST_USER_ID=
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_API_READ_ACCESS_TOKEN=
TMDB_API_KEY=
TMDB_LANGUAGE=en-US
TMDB_WATCH_REGION=US

LLM_PROVIDER=ollama
LLM_MODEL=glm-4.7-flash:latest
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=700
LLM_TIMEOUT_SECONDS=

OLLAMA_API_BASE=http://ollama:11434
OPENAI_API_KEY=
OPENAI_API_BASE=
ANTHROPIC_API_KEY=
ANTHROPIC_API_BASE=
